@using EstadioApp.Models
@using MudBlazor
@inject FirestoreService Firestore

<MudDialog Style="min-width:400px;">
    <DialogContent>
        @if (Enviar)
        {
            <MudPaper Class="pa-4">
                <MudText>Enviando mensaje…</MudText>
            </MudPaper>
        }
        else
        {
            <MudText Typo="Typo.h6" Class="mb-3">
                Enviar mensaje a acomodadores
            </MudText>

            <MudTextField Label="Mensaje"
                           Lines="3"
                           Required="true"
                           @bind-Value="Texto" />

            <MudSelect T="string"
                       Label="Tipo de mensaje"
                       @bind-Value="Tipo"
                       Class="mt-3">

                <MudSelectItem Value="@("general")">General</MudSelectItem>
                <MudSelectItem Value="@("incidencia")">Incidencia</MudSelectItem>
                <MudSelectItem Value="@("zona")">Zona</MudSelectItem>

            </MudSelect>
        }
    </DialogContent>

    <DialogActions>
        @if (!Enviar)
        {
            <MudButton Variant="Variant.Outlined"
                       OnClick="Cancelar">
                Cancelar
            </MudButton>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@string.IsNullOrWhiteSpace(Texto)"
                       OnClick="EnviarMensaje">
                Enviar
            </MudButton>
        }
    </DialogActions>

</MudDialog>

@code {

    [CascadingParameter]
    public MudDialogInstance? Dialog { get; set; }

    string Texto = "";
    string Tipo = "general";
    bool Enviar = false;

    async Task EnviarMensaje()
    {
        if (string.IsNullOrWhiteSpace(Texto))
            return;

        Enviar = true;

        await Firestore.CrearMensajeAsync(
            texto: Texto,
            tipo: Tipo
        );

        Dialog?.Close(DialogResult.Ok(true));
    }

    void Cancelar()
    {
        Dialog?.Cancel();
    }
}
